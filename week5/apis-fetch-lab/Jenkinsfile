pipeline {
    agent any
    tools{
        nodejs "node24"
    }
    environment {
        NODE_ENV = "test"
        BUILD_DIR = "dist"
        APP_NAME = "apis-and-fetch"
    }
    options{
        timeout(time: 15, unit: "MINUTES")
        buildDiscarder(logRotator(numToKeepStr: "10"))
        disableConcurrentBuilds()
    }
    stages {
        stage("Build"){
            steps {
                sh '''
                set -e
                if [ -f "package.json" ]; then
                    APP_DIR="."
                elif [ -f "week5/apis-fetch-lab/package.json" ]; then
                    APP_DIR="week5/apis-fetch-lab"
                else
                    echo "ERROR: package.json not found in workspace root or week5/apis-fetch-lab"
                    exit 1
                fi

                cd "$APP_DIR"
                echo "Using app directory: $PWD"
                echo "Installing dependencies for ${APP_NAME}..."
                npm ci
                echo "Building application..."
                npm run build
                echo "Verifying build output"
                test -d "${BUILD_DIR}" || { echo "ERROR: build directory not found"; exit 1; }
                echo "Build output: $(ls ${BUILD_DIR} | wc -l) files in ${BUILD_DIR}/ "
                '''
            }
        }
        stage("Test"){
            steps {
                echo "Running test suites for ${APP_NAME}"
                sh '''
                    set -e
                    npm test
                '''

            }
        }
        stage("Archive"){
            steps {
                echo "Archive stage: TODO"
            }
        }
    }
    post {
        success {
            echo "Pipeline succeded. ${APP_NAME} build ${BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline FAILED: ${APP_NAME} build ${BUILD_NUMBER} - check logs"
        }
        always {
            echo "Build URL: ${BUILD_URL}"
            junit allowEmptyResults: true,
                testResults: 'test-results/*.xml'
            cleanWs()
        }
    }
}